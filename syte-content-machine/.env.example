# Syte Content Machine — Environment Variables
# Copy this to .env and fill in your values.
# These same variables should be set in Netlify Environment Variables for production.

# Encrypted Anthropic API key (same encrypted key from the original tool)
ENCRYPTED_API_KEY=

# Supabase database connection
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend email API key (sign up at resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email sender address (verify domain in Resend, or use noreply@resend.dev)
EMAIL_FROM=Syte Content Machine <content@syte.co.za>

# JWT session secret (generate a random 32+ character string)
SESSION_SECRET=change-me-to-a-random-32-char-string

# Password for auto-generation scheduled function (same password used to unlock the tool)
AUTO_GENERATE_PASSWORD=
